# Build outputs
bin/
obj/
# bin/ 규칙이 Windows 케이스 무시로 Bin/까지 막으므로 루트 Bin/은 복원
!/Bin/
Bin/output/

# Logs (Bin/logs/ 내 로그 파일 제외, 폴더는 유지)
Bin/logs/*.log

# IDE
.vs/
*.user

# Secrets / environment-specific config
appsettings.Development.json
appsettings.Production.json
appsettings.*.json
!appsettings.json

# Logs
*.log

# Node modules
node_modules/
.claude/hooks/node_modules/

# IDE
.idea/

# Windows artifacts
nul
.claude/settings.local.json
